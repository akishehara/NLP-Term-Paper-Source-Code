
import pandas as pd
import logging
from sklearn.metrics import f1_score, classification_report

# 2. Setup Logging
logging.basicConfig(level=logging.INFO)
transformers_logger = logging.getLogger("transformers")
transformers_logger.setLevel(logging.WARNING)

# 3. Load Data
try:
    train_df = pd.read_csv('train.csv')
    holdback_df = pd.read_csv('holdback.csv')

    # Rename columns to match SimpleTransformers requirements
    train_df = train_df.rename(columns={'samples': 'text', 'targets': 'labels'})
    holdback_df = holdback_df.rename(columns={'samples': 'text', 'targets': 'labels'})

    print(f"Success! Training rows: {len(train_df)}")
    print(f"Testing rows: {len(holdback_df)}")
except FileNotFoundError:
    print("ERROR: Please upload 'train.csv' and 'holdback.csv'first!")
from simpletransformers.classification import ClassificationModel, ClassificationArgs

# Configure BERT
bert_args = ClassificationArgs()
bert_args.num_train_epochs = 3
bert_args.overwrite_output_dir = True
bert_args.manual_seed = 42

# Initialize & Train
print("Starting BERT Training...")
bert_model = ClassificationModel("bert", "bert-base-uncased", num_labels=3, args=bert_args)
bert_model.train_model(train_df)

# Evaluate
predictions_bert, _ = bert_model.predict(holdback_df['text'].tolist())
print("\n--- BERT BASELINE RESULTS ---")
print(classification_report(holdback_df['labels'], predictions_bert, target_names=['Human', 'AI-Base', 'AI-Fine-tuned']))
print(f"BERT Macro F1 Score: {f1_score(holdback_df['labels'], predictions_bert, average='macro'):.4f}")


# Configure RoBERTa
roberta_args = ClassificationArgs()
roberta_args.num_train_epochs = 8
roberta_args.train_batch_size = 16
roberta_args.learning_rate = 2e-5
roberta_args.overwrite_output_dir = True
roberta_args.manual_seed = 42

# Initialize & Train
print("Starting RoBERTa Training...")
roberta_model = ClassificationModel("roberta", "roberta-base", num_labels=3, args=roberta_args)
roberta_model.train_model(train_df)

# Evaluate
predictions_roberta, _ = roberta_model.predict(holdback_df['text'].tolist())
print("\n--- ROBERTA WINNER RESULTS ---")
print(classification_report(holdback_df['labels'], predictions_roberta, target_names=['Human', 'AI-Base', 'AI-Fine-tuned']))
print(f"RoBERTa Macro F1 Score: {f1_score(holdback_df['labels'], predictions_roberta, average='macro'):.4f}")
